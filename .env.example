# Velora - Environment Variables
# Copy this file and rename to .env (for API) or .env.local (for Web)

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:velora_secret@localhost:5432/velora_db"
REDIS_URL="redis://:velora_redis_secret@localhost:6379"

# ── Authentication (Supabase Auth) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Payments (Stripe) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_YOUR_PREMIUM_MONTHLY
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_YOUR_PREMIUM_ANNUAL
STRIPE_GOLD_MONTHLY_PRICE_ID=price_YOUR_GOLD_MONTHLY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=hello@velora.com
RESEND_FROM_NAME=Velora

# ── Media (Cloudinary) ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME

# ── Analytics (PostHog) ──────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_YOUR_POSTHOG_KEY
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── AI (OpenAI - Optional) ───────────────────────────────────
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o

# ── Application ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3001
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_32_chars_or_more
ENCRYPTION_KEY=change_me_32_char_key_abcdefgh12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Socket.io ────────────────────────────────────────────────
SOCKET_CORS_ORIGIN=http://localhost:3000

# ── Admin ────────────────────────────────────────────────────
ADMIN_SECRET_KEY=change_this_admin_key
